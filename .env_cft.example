# CFT prop 2-Step (DOT/AVAX/RUNE/ETC/XLM) — отдельный CFT-Bybit аккаунт.
# Скопируй в .env_cft и впиши API-ключ Bybit-аккаунта, привязанного к CFT-дашборду.
#   cp .env_cft.example .env_cft && nano .env_cft
#
# MODE: уточни у CFT, какой Bybit-аккаунт они дают под evaluation —
#   DEMO  -> движок бьёт по api-demo.bybit.com (по умолчанию, как наши боты)
#   REAL  -> api.bybit.com (если CFT даёт реальный/спец-аккаунт)
MODE=DEMO
BYBIT_API_KEY=your_cft_linked_bybit_key_here
BYBIT_API_SECRET=your_cft_linked_bybit_secret_here
BYBIT_BOT_NUMBER=cft

# Telegram-уведомления (опционально; отдельный токен/чат для CFT-бота)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_TRADES=0
