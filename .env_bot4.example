# Bot #4 (DEMO) — отдельный Bybit demo-аккаунт (DOT/AVAX/RUNE).
# Скопируй в .env_bot4 и впиши ключи demo-аккаунта (свои, не от других ботов).
#   cp .env_bot4.example .env_bot4 && nano .env_bot4
MODE=DEMO
BYBIT_API_KEY=your_demo_api_key_here
BYBIT_API_SECRET=your_demo_api_secret_here
BYBIT_BOT_NUMBER=4

# Telegram-уведомления (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
