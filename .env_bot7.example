# Bot #7 (prop-aware champion) — отдельный Bybit demo-аккаунт.
# Скопируй в .env_bot7 и впиши ключи НОВОГО demo-аккаунта (свои, не от других ботов).
#   cp .env_bot7.example .env_bot7 && nano .env_bot7
MODE=DEMO
BYBIT_API_KEY=your_demo_api_key_here
BYBIT_API_SECRET=your_demo_api_secret_here
BYBIT_BOT_NUMBER=7

# Telegram-уведомления (опционально; можно отдельный токен/чат для bot7)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_TRADES=0
