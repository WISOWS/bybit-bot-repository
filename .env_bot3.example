# Bot #3 (DEMO) — отдельный Bybit demo-аккаунт (ATOM/INJ/TIA).
# Скопируй в .env_bot3 и впиши ключи demo-аккаунта (свои, не от других ботов).
#   cp .env_bot3.example .env_bot3 && nano .env_bot3
MODE=DEMO
BYBIT_API_KEY=your_demo_api_key_here
BYBIT_API_SECRET=your_demo_api_secret_here
BYBIT_BOT_NUMBER=3

# Telegram-уведомления (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
