# Bot #5 (DEMO) — отдельный Bybit demo-аккаунт (OP/ARB/TON).
# Скопируй в .env_bot5 и впиши ключи demo-аккаунта (свои, не от других ботов).
#   cp .env_bot5.example .env_bot5 && nano .env_bot5
MODE=DEMO
BYBIT_API_KEY=your_demo_api_key_here
BYBIT_API_SECRET=your_demo_api_secret_here

# Telegram-уведомления (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
