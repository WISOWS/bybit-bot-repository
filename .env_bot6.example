# Bot #6 (DEMO) — отдельный Bybit demo-аккаунт (SNX/BNB/BCH/ETH/DOGE/ADA).
# Скопируй в .env_bot6 и впиши ключи demo-аккаунта (свои, не от других ботов).
#   cp .env_bot6.example .env_bot6 && nano .env_bot6
MODE=DEMO
BYBIT_API_KEY=your_demo_api_key_here
BYBIT_API_SECRET=your_demo_api_secret_here
BYBIT_BOT_NUMBER=6

# Telegram-уведомления (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
