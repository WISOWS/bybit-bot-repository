# Bot #2 (DEMO) — отдельный Bybit demo-аккаунт.
# Скопируй в .env_bot2 и впиши ключи demo-аккаунта (НЕ те же, что у бота #1).
#   cp .env_bot2.example .env_bot2 && nano .env_bot2
MODE=DEMO
BYBIT_API_KEY=your_demo_api_key_here
BYBIT_API_SECRET=your_demo_api_secret_here
BYBIT_BOT_NUMBER=2

# Telegram-уведомления (опционально; можно отдельный бот/чат для bot2)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
